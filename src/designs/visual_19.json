    "id": "visual_19",
    "title": "AI Prompt Interface",
    "category": "UI Inspiration",
    "visual_html": "<div class=\"border-2 border-black rounded-xl overflow-hidden bg-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] w-full max-w-full mx-auto\">\n<div class=\"bg-[#f38020] border-b-2 border-black px-4 py-1.5 flex items-center justify-between\">\n<div class=\"flex items-center space-x-2 text-white\">\n<svg class=\"w-6 h-6\" fill=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M19.4 9.6a7.5 7.5 0 00-14.8-1.4 5.5 5.5 0 101.4 10.8h12a4.5 4.5 0 100-9z\"></path></svg>\n<span class=\"font-bold text-xs tracking-wide\">CLOUDFLARE DEPLOYMENT</span>\n</div>\n<span class=\"bg-white text-[#f38020] text-[10px] font-bold px-2 py-0.5 rounded-full border border-black uppercase\">Free Static Hosting</span>\n</div>\n<div class=\"p-4 bg-gray-50\">\n<!-- Claude Instruction -->\n<div class=\"flex items-start space-x-3 bg-white border-2 border-black rounded-lg p-3 mb-2 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]\">\n<div class=\"w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center border border-purple-300 flex-shrink-0\">\n<svg class=\"w-5 h-5 text-purple-600\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M13 10V3L4 14h7v7l9-11h-7z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n</div>\n<div>\n<div class=\"text-xs font-bold text-gray-500 mb-0.5\">Claude Code Prompt</div>\n<div class=\"text-xs font-medium\">\"Deploy this website to Cloudflare Pages.\"</div>\n</div>\n</div>\n<!-- Terminal Output -->\n<div class=\"rounded-lg overflow-hidden border-2 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]\">\n<div class=\"bg-gray-800 px-4 py-2 flex space-x-2 border-b border-gray-700\">\n<div class=\"w-3 h-3 rounded-full bg-red-500\"></div>\n<div class=\"w-3 h-3 rounded-full bg-yellow-500\"></div>\n<div class=\"w-3 h-3 rounded-full bg-green-500\"></div>\n</div>\n<div class=\"bg-gray-900 p-4 font-mono text-[13px] leading-relaxed text-gray-300 space-y-1\">\n<div class=\"flex\"><span class=\"text-green-400 mr-2\">$</span> <span class=\"text-white\">npx wrangler login</span></div>\n<div class=\"text-gray-400\">Opening browser... Authorize Cloudflare?</div>\n<div class=\"text-blue-300 hover:text-blue-200 cursor-pointer underline\">[Authorize]</div>\n<div class=\"flex items-center text-green-400\"><svg class=\"w-4 h-4 mr-1\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M5 13l4 4L19 7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg> Successfully logged in.</div>\n<div class=\"flex mt-3\"><span class=\"text-green-400 mr-2\">$</span> <span class=\"text-white\">npm run deploy</span></div>\n<div class=\"text-yellow-300\">&gt; Deployed to real-online-ruler.pages.dev</div>\n</div>\n</div>\n<!-- Result Link -->\n<div class=\"mt-2 flex items-center justify-center space-x-2 text-xs\">\n<span class=\"text-gray-600 font-medium\">Temporary URL:</span>\n<a class=\"text-blue-600 hover:text-blue-800 underline font-mono font-bold bg-blue-50 px-2 py-0.5 rounded border border-blue-200\" href=\"#\">https://real-online-ruler.pages.dev</a>\n</div>\n</div>\n</div>",
    "metadata_html": "<div class=\"mb-4\">\n<h4 class=\"font-medium font-sans text-white text-sm mb-2\">Why I saved this:</h4>\n<ul class=\"list-disc pl-5 font-sans text-sm text-[var(--arsenal-text)] space-y-1\"><li>Keyword chip design</li><li>Clear conversational structure</li><li>Subtle border styling</li></ul>\n</div>\n<div class=\"mb-6\">\n<h4 class=\"font-medium font-sans text-white text-sm mb-2\">What I can learn:</h4>\n<ul class=\"list-disc pl-5 font-sans text-sm text-[var(--arsenal-text)] space-y-1\"><li>Structuring LLM outputs visually</li><li>Tag system UI patterns</li></ul>\n</div>\n<!-- RESTORED: SOURCE METADATA -->\n<div class=\"transparent p-4 rounded border border-white/20 text-sm mt-4 hidden\">\n<div class=\"grid grid-cols-3 gap-y-2 gap-x-4\">\n<div class=\"font-mono text-gray-500\">Creator:</div>\n<div class=\"col-span-2 font-medium text-[var(--text-primary)]\">Tejas Jaware</div>\n<div class=\"font-mono text-gray-500\">Source:</div>\n<div class=\"col-span-2 text-[var(--text-primary)]\"><a class=\"underline font-bold text-[var(--text-primary)] hover:text-indigo-500\" href=\"paper_micro_tool.html\" onclick=\"event.stopPropagation()\">AI Micro-Tools Guide</a></div>\n<div class=\"font-mono text-gray-500 mt-2 pt-2 border-t border-gray-200\">Rights:</div>\n<div class=\"col-span-2 text-gray-500 text-xs italic leading-tight mt-2 pt-2 border-t border-gray-200\">Belongs to original creator. Saved for inspiration.</div>\n</div>\n</div>"
