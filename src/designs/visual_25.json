-white text-black font-bold text-xs shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] z-10 shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2\">\n                    2\n                </div>\n<div class=\"w-[calc(100%-3rem)] md:w-[calc(50%-2rem)] p-3 rounded-lg border-2 border-black bg-gray-50 shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] my-2\">\n<div class=\"font-bold text-xs mb-1\">Add site to AdSense</div>\n<div class=\"text-xs text-gray-600\">ads.google.com \u2192 Add Site \u2192 realonlineruler.com</div>\n</div>\n</div>\n<div class=\"relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active\">\n<div class=\"flex items-center justify-center w-8 h-8 rounded-full border-2 border-black bg-white text-black font-bold text-xs shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] z-10 shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2\">\n                    3\n                </div>\n<div class=\"w-[calc(100%-3rem)] md:w-[calc(50%-2rem)] p-3 rounded-lg border-2 border-black bg-gray-50 shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] my-2\">\n<div class=\"font-bold text-xs mb-1\">Add script to header</div>\n<div class=\"text-xs text-gray-600\">Claude Code: \"Add this script to header\" then <span class=\"font-mono bg-gray-200 px-1 rounded\">$ npm run deploy</span></div>\n</div>\n</div>\n<div class=\"relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active\">\n<div class=\"flex items-center justify-center w-8 h-8 rounded-full border-2 border-black bg-white text-black font-bold text-xs shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] z-10 shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2\">\n                    4\n                </div>\n<div class=\"w-[calc(100%-3rem)] md:w-[calc(50%-2rem)] p-3 rounded-lg border-2 border-black bg-gray-50 shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] my-2\">\n<div class=\"font-bold text-xs mb-1\">Add ads.txt</div>\n<div cl