    "visual_html": "<div class=\"bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden font-sans max-w-full mx-auto\">\n<!-- Browser Header -->\n<div class=\"bg-gray-100 border-b border-gray-200 pt-3 px-4 flex items-end gap-2\">\n<div class=\"flex gap-1.5 mb-1.5 mr-2\">\n<div class=\"w-3 h-3 rounded-full bg-red-400\"></div>\n<div class=\"w-3 h-3 rounded-full bg-yellow-400\"></div>\n<div class=\"w-3 h-3 rounded-full bg-green-400\"></div>\n</div>\n<!-- Tab 1 -->\n<div class=\"bg-white border border-gray-200 border-b-0 rounded-t-lg px-4 py-2 text-xs font-medium text-gray-700 flex items-center gap-2 max-w-[200px] w-full relative z-10 shadow-sm\">\n<svg class=\"w-3.5 h-3.5 text-blue-500\" fill=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M12.24 10.285V14.4h6.806c-.275 1.765-2.056 5.174-6.806 5.174-4.095 0-7.439-3.389-7.439-7.574s3.345-7.574 7.439-7.574c2.33 0 3.891.989 4.785 1.849l3.254-3.138C18.189 1.186 15.479 0 12.24 0c-6.635 0-12 5.365-12 12s5.365 12 12 12c6.926 0 11.52-4.869 11.52-11.726 0-.788-.085-1.39-.189-1.989H12.24z\"></path></svg>\n<span class=\"truncate\">Google Search</span>\n</div>\n<!-- Tab 2 -->\n<div class=\"bg-gray-200 border border-gray-300 border-b-0 rounded-t-lg px-4 py-2 text-xs text-gray-500 flex items-center gap-2 max-w-[200px] w-full\">\n<span class=\"w-3.5 h-3.5 bg-orange-500 rounded text-white flex items-center justify-center font-bold text-[8px]\">a</span>\n<span class=\"truncate\">Ahrefs Keyword Generator</span>\n</div>\n</div>\n<!-- Split Layout -->\n<div class=\"flex flex-col lg:flex-row divide-y lg:divide-y-0 lg:divide-x divide-gray-200 bg-gray-50/30\">\n<!-- Left: Google Autocomplete -->\n<div class=\"flex-1 p-4 flex flex-col items-center\">\n<div class=\"text-3xl font-bold text-gray-800 mb-6 mt-2\"><span class=\"text-blue-500\">G</span><span class=\"text-red-500\">o</span><span class=\"text-yellow-500\">o</span><span class=\"text-blue-500\">g</span><span class=\"text-green-500\">l</span><span class=\"text-red-500\">e</span></div>\n<div class=\"w-full max-w-md bg-white border border-gray-200 rounded-2xl shadow-md overflow-hidden\">\n<div class=\"flex items-center px-4 py-1.5 border-b border-gray-100\">\n<svg class=\"w-4 h-4 text-gray-400 mr-3\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n<span class=\"text-gray-800 text-xs\">online ruler </span><span class=\"w-[1px] h-4 bg-black animate-pulse ml-px\"></span>\n</div>\n<div class=\"py-2\">\n<div class=\"px-4 py-2 hover:bg-gray-50 flex items-center text-xs text-gray-700 font-medium cursor-default\">\n<svg class=\"w-3 h-3 text-gray-400 mr-3\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n                        online ruler <span class=\"font-normal text-gray-500 ml-1\">in inches</span>\n</div>\n<div class=\"px-4 py-2 hover:bg-gray-50 flex items-center text-xs text-gray-700 font-medium cursor-default\">\n<svg class=\"w-3 h-3 text-gray-400 mr-3\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n                        online ruler <span class=\"font-normal text-gray-500 ml-1\">cm</span>\n</div>\n<div class=\"px-4 py-2 hover:bg-gray-50 flex items-center text-xs text-gray-700 font-medium cursor-default\">\n<svg class=\"w-3 h-3 text-gray-400 mr-3\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n                        online ruler <span class=\"font-normal text-gray-500 ml-1\">for phone screen</span>\n</div>\n</div>\n</div>\n</div>\n<!-- Right: Ahrefs Data -->\n<div class=\"flex-1 p-4\">\n<div class=\"flex items-center justify-between mb-2\">\n<h4 class=\"font-semibold text-gray-800 text-lg m-0 p-0 border-0\">Keyword Generator</h4>\n<span class=\"text-xs font-medium text-orange-600 bg-orange-50 px-2 py-1 rounded border border-orange-200\">United States</span>\n</div>\n<div class=\"bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden mb-2\">\n<table class=\"w-full text-left text-xs m-0\">\n<thead class=\"bg-gray-50 text-gray-500 text-xs uppercase border-b border-gray-200\">\n<tr><th class=\"px-4 py-2 font-medium border-0\">Keyword</th><th class=\"px-4 py-2 font-medium text-right border-0\">KD</th><th class=\"px-4 py-2 font-medium text-right border-0\">Volume</th></tr>\n</thead>\n<tbody class=\"divide-y divide-gray-100\">\n<tr>\n<td class=\"px-4 py-1.5 font-medium text-gray-800 border-0\">online ruler</td>\n<td class=\"px-4 py-1.5 text-right border-0\"><span class=\"inline-block w-6 h-6 rounded-full bg-green-100 text-green-700 text-xs flex items-center justify-center font-bold\">12</span></td>\n<td class=\"px-4 py-1.5 text-right text-gray-600 border-0\">22,000</td>\n</tr>\n<tr>\n<td class=\"px-4 py-1.5 font-medium text-gray-800 border-0\">online ruler actual size</td>\n<td class=\"px-4 py-1.5 text-right border-0\"><span class=\"inline-block w-6 h-6 rounded-full bg-green-100 text-green-700 text-xs flex items-center justify-center font-bold\">4</span></td>\n<td class=\"px-4 py-1.5 text-right text-gray-600 border-0\">8,500</td>\n</tr>\n</tbody>\n</table>\n</div>\n<div class=\"bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden\">\n<div class=\"bg-gray-50 px-4 py-2 border-b border-gray-200 text-xs font-semibold text-gray-600 uppercase tracking-wider\">Questions (FAQ Ideas)</div>\n<div class=\"p-3 text-xs text-gray-700\">\n<ul class=\"space-y-2 list-none p-0 m-0\">\n<li class=\"flex items-start m-0\"><svg class=\"w-4 h-4 text-blue-500 mr-2 mt-0.5 shrink-0\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>How to measure online? <span class=\"ml-auto text-xs text-gray-400\">1,200</span></li>\n<li class=\"flex items-start m-0\"><svg class=\"w-4 h-4 text-blue-500 mr-2 mt-0.5 shrink-0\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>Is online ruler accurate? <span class=\"ml-auto text-xs text-gray-400\">800</span></li>\n</ul>\n</div>\n</div>\n</div>\n</div>\n</div>",
    "metadata_html": "<div class=\"mb-4\">\n<h4 class=\"font-medium font-sans text-white text-sm mb-2\">Why I saved this:</h4>\n<ul class=\"list-disc pl-5 font-sans text-sm text-[var(--arsenal-text)] space-y-1\"><li>Abstracted UI framing</li><li>Neutral color palette</li><li>Focuses attention on inner content</li></ul>\n</div>\n<div class=\"mb-6\">\n<h4 class=\"font-medium font-sans text-white text-sm mb-2\">What I can learn:</h4>\n<ul class=\"list-disc pl-5 font-sans text-sm text-[var(--arsenal-text)] space-y-1\"><li>Using pseudo-browser frames for presentations</li><li>Creating depth with borders</li></ul>\n</div>\n<!-- RESTORED: SOURCE METADATA -->\n<div class=\"transparent p-4 rounded border border-white/20 text-sm mt-4 hidden\">\n<div class=\"grid grid-cols-3 gap-y-2 gap-x-4\">\n<div class=\"font-mono text-gray-500\">Creator:</div>\n<div class=\"col-span-2 font-medium text-[var(--text-primary)]\">Tejas Jaware</div>\n<div class=\"font-mono text-gray-500\">Source:</div>\n<div class=\"col-span-2 text-[var(--text-primary)]\"><a class=\"underline font-bold text-[var(--text-primary)] hover:text-indigo-500\" href=\"paper_micro_tool.html\" onclick=\"event.stopPropagation()\">AI Micro-Tools Guide</a></div>\n<div class=\"font-mono text-gray-500 mt-2 pt-2 border-t border-gray-200\">Rights:</div>\n<div class=\"col-span-2 text-gray-500 text-xs italic leading-tight mt-2 pt-2 border-t border-gray-200\">Belongs to original creator. Saved for inspiration.</div>\n</div>\n</div>"
