    "visual_html": "<div class=\"bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden font-sans max-w-full mx-auto\">\n<div class=\"bg-gray-50 border-b border-gray-200 px-4 py-2 flex items-center gap-3\">\n<svg class=\"w-5 h-5 text-yellow-500\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n<span class=\"font-semibold text-gray-800 text-xs tracking-wide uppercase\">Problem Discovery Process</span>\n</div>\n<div class=\"p-4 md:p-8 flex flex-col md:flex-row gap-8 items-center justify-center bg-gray-50/50\">\n<!-- Phone Search -->\n<div class=\"flex-1 w-full max-w-[240px] bg-white border-4 border-gray-800 rounded-3xl h-[400px] shadow-lg flex flex-col overflow-hidden relative\">\n<div class=\"h-6 w-32 bg-gray-800 mx-auto rounded-b-xl absolute top-0 left-1/2 -translate-x-1/2\"></div>\n<div class=\"flex-1 p-4 pt-10 flex flex-col\">\n<div class=\"text-center font-bold text-xl mb-6\">Google</div>\n<div class=\"w-full bg-gray-100 rounded-full py-2 px-4 text-xs text-gray-600 border border-gray-200 flex items-center shadow-inner\">\n<svg class=\"w-4 h-4 mr-2 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n                    online ruler\n                </div>\n<div class=\"mt-3 flex-1 flex flex-col gap-3\">\n<div class=\"w-full h-20 bg-gray-50 rounded-lg border border-gray-200 p-2\">\n<div class=\"w-2/3 h-2 bg-blue-200 rounded mb-2\"></div>\n<div class=\"w-full h-2 bg-gray-200 rounded mb-1\"></div>\n<div class=\"w-4/5 h-2 bg-gray-200 rounded\"></div>\n</div>\n<div class=\"w-full h-20 bg-gray-50 rounded-lg border border-gray-200 p-2\">\n<div class=\"w-2/3 h-2 bg-blue-200 rounded mb-2\"></div>\n<div class=\"w-full h-2 bg-gray-200 rounded mb-1\"></div>\n<div class=\"w-4/5 h-2 bg-gray-200 rounded\"></div>\n</div>\n</div>\n</div>\n</div>\n<!-- Arrow -->\n<div class=\"text-gray-300 hidden md:block\">\n<svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M14 5l7 7m0 0l-7 7m7-7H3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n</div>\n<div class=\"text-gray-300 block md:hidden\">\n<svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M19 14l-7 7m0 0l-7-7m7 7V3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n</div>\n<!-- Competitor UI -->\n<div class=\"flex-1 w-full max-w-[320px] bg-white border border-gray-200 rounded-lg shadow-lg overflow-hidden flex flex-col\">\n<div class=\"bg-gray-100 px-3 py-2 border-b border-gray-200 flex items-center gap-2\">\n<div class=\"flex gap-1.5\">\n<div class=\"w-2.5 h-2.5 rounded-full bg-red-400\"></div>\n<div class=\"w-2.5 h-2.5 rounded-full bg-yellow-400\"></div>\n<div class=\"w-2.5 h-2.5 rounded-full bg-green-400\"></div>\n</div>\n<div class=\"bg-white text-[10px] text-gray-500 py-1 px-4 rounded border border-gray-200 flex-1 ml-2 text-center truncate\">competitor-ruler.com</div>\n</div>\n<div class=\"p-4 flex-1 flex flex-col items-center justify-center gap-2 bg-gray-50\">\n<!-- Clunky Ruler -->\n<div class=\"w-full bg-white border border-gray-200 rounded p-4 shadow-sm relative\">\n<div class=\"w-full h-8 bg-yellow-100 border-2 border-yellow-300 flex justify-between px-2 pt-1 opacity-70 mb-2\">\n<div class=\"h-full w-px bg-yellow-400\"></div><div class=\"h-2 w-px bg-yellow-400\"></div><div class=\"h-4 w-px bg-yellow-400\"></div><div class=\"h-2 w-px bg-yellow-400\"></div><div class=\"h-full w-px bg-yellow-400\"></div>\n</div>\n<div class=\"text-center text-xs text-gray-500 font-serif italic\">\"Why does this look like it's from 2005?\"</div>\n</div>\n<!-- Annotations (Flex Layout, no absolute overlap) -->\n<div class=\"w-full flex flex-col gap-3\">\n<div class=\"text-red-500 flex items-center gap-2\">\n<svg class=\"w-5 h-5 shrink-0\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n<span class=\"text-xs font-medium bg-red-50 px-3 py-1 rounded border border-red-200 shadow-sm w-full\">Not mobile friendly</span>\n</div>\n<div class=\"text-red-500 flex items-center gap-2\">\n<svg class=\"w-5 h-5 shrink-0\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n<span class=\"text-xs font-medium bg-red-50 px-3 py-1 rounded border border-red-200 shadow-sm w-full\">Too many ads</span>\n</div>\n</div>\n<div class=\"mt-2 w-full text-green-700 bg-green-50 border border-green-200 px-4 py-2 rounded-lg text-xs font-semibold shadow-sm flex items-center justify-center\">\n<svg class=\"w-5 h-5 mr-2\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M13 10V3L4 14h7v7l9-11h-7z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n                    Idea: Build a cleaner version\n                </div>\n</div>\n</div>\n</div>\n</div>",
    "metadata_html": "<div class=\"mb-4\">\n<h4 class=\"font-medium font-sans text-white text-sm mb-2\">Why I saved this:</h4>\n<ul class=\"list-disc pl-5 font-sans text-sm text-[var(--arsenal-text)] space-y-1\"><li>Effective use of whitespace</li><li>Soft rounded corners</li></ul>\n</div>\n<div class=\"mb-6\">\n<h4 class=\"font-medium font-sans text-white text-sm mb-2\">What I can learn:</h4>\n<ul class=\"list-disc pl-5 font-sans text-sm text-[var(--arsenal-text)] space-y-1\"><li>Spacing rhythm in research docs</li></ul>\n</div>\n<!-- RESTORED: SOURCE METADATA -->\n<div class=\"transparent p-4 rounded border border-white/20 text-sm mt-4 hidden\">\n<div class=\"grid grid-cols-3 gap-y-2 gap-x-4\">\n<div class=\"font-mono text-gray-500\">Creator:</div>\n<div class=\"col-span-2 font-medium text-[var(--text-primary)]\">Tejas Jaware</div>\n<div class=\"font-mono text-gray-500\">Source:</div>\n<div class=\"col-span-2 text-[var(--text-primary)]\"><a class=\"underline font-bold text-[var(--text-primary)] hover:text-indigo-500\" href=\"paper_micro_tool.html\" onclick=\"event.stopPropagation()\">AI Micro-Tools Guide</a></div>\n<div class=\"font-mono text-gray-500 mt-2 pt-2 border-t border-gray-200\">Rights:</div>\n<div class=\"col-span-2 text-gray-500 text-xs italic leading-tight mt-2 pt-2 border-t border-gray-200\">Belongs to original creator. Saved for inspiration.</div>\n</div>\n</div>"
