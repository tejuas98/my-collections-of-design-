    "visual_html": "<div class=\"bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden font-sans max-w-full mx-auto\">\n<div class=\"bg-gray-50 border-b border-gray-200 px-4 py-2 flex items-center gap-3\">\n<svg class=\"w-5 h-5 text-indigo-500\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n<span class=\"font-semibold text-gray-800 text-xs tracking-wide uppercase m-0\">Polishing the UI: Dark Mode &amp; Mobile</span>\n</div>\n<div class=\"p-4 md:p-8 flex flex-col gap-8 bg-gray-100\">\n<div class=\"flex flex-col lg:flex-row gap-2 items-center lg:items-end justify-center\">\n<!-- Desktop Browser (Dark Mode) -->\n<div class=\"flex-1 w-full max-w-lg bg-[#1e1e1e] border border-gray-700 rounded-xl shadow-2xl flex flex-col overflow-hidden relative\">\n<!-- Browser Header -->\n<div class=\"bg-[#323233] border-b border-[#1e1e1e] pt-3 px-4 flex items-end gap-2\">\n<div class=\"flex gap-1.5 mb-1.5 mr-2\">\n<div class=\"w-3 h-3 rounded-full bg-gray-500\"></div>\n<div class=\"w-3 h-3 rounded-full bg-gray-500\"></div>\n<div class=\"w-3 h-3 rounded-full bg-gray-500\"></div>\n</div>\n<div class=\"bg-[#1e1e1e] border-t border-l border-r border-[#3c3c3c] rounded-t-lg px-4 py-1.5 text-xs text-gray-300 flex items-center gap-2\">\n<div class=\"w-3.5 h-3.5 bg-yellow-500 rounded-sm\"></div>\n                        Real Online Ruler\n                    </div>\n</div>\n<!-- Browser App -->\n<div class=\"bg-[#121212] flex-1 p-4 relative min-h-[250px] flex flex-col items-center justify-center border-t border-[#3c3c3c]\">\n<div class=\"absolute top-4 right-4 bg-[#2d2d2d] border border-[#444] rounded-full p-1.5 shadow-md\">\n<svg class=\"w-4 h-4 text-yellow-400\" fill=\"currentColor\" viewbox=\"0 0 20 20\"><path d=\"M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z\"></path></svg>\n</div>\n<div class=\"w-full h-8 border-b-2 border-yellow-500 absolute top-0 left-0 flex justify-between px-4 pt-2 opacity-60\">\n<div class=\"h-full w-0.5 bg-yellow-500\"></div><div class=\"h-2 w-px bg-yellow-500\"></div><div class=\"h-4 w-px bg-yellow-500\"></div><div class=\"h-2 w-px bg-yellow-500\"></div><div class=\"h-full w-0.5 bg-yellow-500\"></div>\n</div>\n<div class=\"text-white text-lg font-semibold m-0\">Desktop Dark Mode</div>\n<div class=\"text-gray-400 text-xs mt-2 m-0\">Sleek interface for night owls</div>\n</div>\n</div>\n<!-- Mobile Simulator -->\n<div class=\"w-full max-w-[220px] bg-black border-[6px] border-gray-800 rounded-[2.5rem] h-[450px] shadow-2xl flex flex-col overflow-hidden relative\">\n<div class=\"h-5 w-24 bg-gray-800 mx-auto rounded-b-xl absolute top-0 left-1/2 -translate-x-1/2 z-20\"></div>\n<!-- App -->\n<div class=\"flex-1 bg-white relative flex flex-col mt-2 rounded-[2rem] overflow-hidden\">\n<div class=\"pt-8 pb-3 px-4 flex justify-between items-center bg-gray-50 border-b border-gray-200\">\n<div class=\"flex items-center gap-1\">\n<div class=\"w-3.5 h-3.5 bg-yellow-500 rounded-sm\"></div>\n<span class=\"text-xs font-bold text-gray-800 m-0\">Ruler</span>\n</div>\n<svg class=\"w-4 h-4 text-gray-500\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M4 6h16M4 12h16M4 18h16\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n</div>\n<div class=\"flex-1 flex flex-col items-center justify-center p-4\">\n<div class=\"w-full border-2 border-yellow-400 rounded-lg h-32 flex justify-between p-2 mb-2 bg-yellow-50 shadow-inner\">\n<div class=\"h-full flex flex-col justify-between items-end opacity-70\">\n<div class=\"w-4 h-px bg-yellow-600\"></div><div class=\"w-2 h-px bg-yellow-600\"></div><div class=\"w-2 h-px bg-yellow-600\"></div><div class=\"w-4 h-px bg-yellow-600\"></div>\n</div>\n<div class=\"text-center self-center text-[10px] font-bold text-gray-700 -rotate-90 whitespace-nowrap opacity-50 m-0\">Fits Mobile Screen Perfectly</div>\n</div>\n<div class=\"text-xs font-bold bg-blue-100 text-blue-700 px-3 py-1.5 rounded-lg w-full text-center mb-2 shadow-sm m-0\">Inches</div>\n<div class=\"text-xs font-bold bg-gray-100 text-gray-700 px-3 py-1.5 rounded-lg w-full text-center shadow-sm m-0\">CM</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>",
