    "visual_html": "<div class=\"bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden font-sans max-w-full mx-auto\">\n<div class=\"bg-gray-50 border-b border-gray-200 px-4 py-2 flex items-center gap-3\">\n<svg class=\"w-5 h-5 text-blue-600\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n<span class=\"font-semibold text-gray-800 text-xs tracking-wide uppercase m-0\">MCP (Model Context Protocol) Setup</span>\n</div>\n<div class=\"p-4 flex flex-col items-center bg-gray-50\">\n<!-- Top Section: Data Sources -->\n<div class=\"flex flex-col md:flex-row items-center gap-2 w-full max-w-2xl\">\n<!-- Left: Base Training -->\n<div class=\"flex-1 w-full bg-white border border-gray-300 rounded-lg p-4 shadow-sm text-center relative h-20 flex flex-col justify-center\">\n<svg class=\"w-8 h-4 text-gray-400 mx-auto mb-0.5\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n<div class=\"font-bold text-gray-800 m-0\">Base Training Data</div>\n<div class=\"text-xs text-red-500 font-medium m-0\">(May be outdated)</div>\n</div>\n<!-- Plus Icon -->\n<div class=\"text-blue-500 bg-white p-2 rounded-full shadow-sm border border-gray-200 z-10 shrink-0\">\n<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M12 4v16m8-8H4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n</div>\n<!-- Right: MCP Server -->\n<div class=\"flex-1 w-full bg-blue-50 border-2 border-blue-400 rounded-lg p-4 shadow-md text-center relative h-20 flex flex-col justify-center\">\n<svg class=\"w-8 h-4 text-blue-600 mx-auto mb-0.5\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M13 10V3L4 14h7v7l9-11h-7z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n<div class=\"font-bold text-blue-900 m-0\">Astro MCP Server</div>\n<div class=\"text-xs text-blue-700 font-medium m-0\">Provides LIVE Documentation</div>\n<div class=\"absolute -top-3 -right-3 bg-green-500 text-white text-[10px] font-bold px-2 py-1 rounded-full shadow-sm animate-pulse\">LIVE</div>\n</div>\n</div>\n<!-- Arrows Down -->\n<div class=\"flex justify-center w-full max-w-2xl my-2 relative\">\n<div class=\"w-1/2 flex justify-center\"><div class=\"h-4 w-px bg-gray-400\"></div></div>\n<div class=\"w-1/2 flex justify-center\"><div class=\"h-4 w-px bg-blue-400\"></div></div>\n<div class=\"absolute top-4 w-1/2 h-px bg-gray-400 right-1/2\"></div>\n<div class=\"absolute top-4 w-1/2 h-px bg-blue-400 left-1/2\"></div>\n<div class=\"absolute top-4 left-1/2 -translate-x-1/2 w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-t-[8px] border-t-gray-500 mt-2\"></div>\n<div class=\"h-4 w-px bg-gradient-to-b from-transparent to-purple-500 mt-4 mx-auto\"></div>\n</div>\n<!-- Middle: AI Agent -->\n<div class=\"w-full max-w-sm bg-gray-900 border border-gray-800 rounded-xl p-4 shadow-xl text-center relative overflow-hidden\">\n<div class=\"absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-purple-500 to-blue-500\"></div>\n<div class=\"text-white font-bold text-base mb-1 m-0\">Claude Code</div>\n<div class=\"text-gray-400 text-xs m-0\">AI Coding Agent</div>\n<div class=\"mt-2 bg-gray-800 rounded border border-gray-700 p-2 text-xs font-mono text-green-400\">\n                Reading latest syntax... \u2713\n            </div>\n</div>\n<!-- Arrow Down -->\n<div class=\"my-2\">\n<svg class=\"w-6 h-6 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M19 14l-7 7m0 0l-7-7m7 7V3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n</div>\n<!-- Bottom: Output -->\n<div class=\"w-full max-w-lg bg-white border border-green-300 rounded-lg p-4 shadow-sm text-center\">\n<div class=\"font-bold text-gray-900 text-base m-0 flex justify-center items-center gap-2\">\n<svg class=\"w-6 h-6 text-green-500\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n                Accurate Astro Code Generation\n            </div>\n<div class=\"text-xs text-gray-500 mt-1 m-0\">Uses correct components and modern best practices.</div>\n</div>\n</div>\n<!-- Terminal Command Banner -->\n</div>",
    "metadata_html": "<div class=\"mb-4\">\n<h4 class=\"font-medium font-sans text-white text-sm mb-2\">Why I saved this:</h4>\n<ul class=\"list-disc pl-5 font-sans text-sm text-[var(--arsenal-text)] space-y-1\"><li>Keyword chip design</li><li>Clear conversational structure</li><li>Subtle border styling</li></ul>\n</div>\n<div class=\"mb-6\">\n<h4 class=\"font-medium font-sans text-white text-sm mb-2\">What I can learn:</h4>\n<ul class=\"list-disc pl-5 font-sans text-sm text-[var(--arsenal-text)] space-y-1\"><li>Structuring LLM outputs visually</li><li>Tag system UI patterns</li></ul>\n</div>\n<!-- RESTORED: SOURCE METADATA -->\n<div class=\"transparent p-4 rounded border border-white/20 text-sm mt-4 hidden\">\n<div class=\"grid grid-cols-3 gap-y-2 gap-x-4\">\n<div class=\"font-mono text-gray-500\">Creator:</div>\n<div class=\"col-span-2 font-medium text-[var(--text-primary)]\">Tejas Jaware</div>\n<div class=\"font-mono text-gray-500\">Source:</div>\n<div class=\"col-span-2 text-[var(--text-primary)]\"><a class=\"underline font-bold text-[var(--text-primary)] hover:text-indigo-500\" href=\"paper_micro_tool.html\" onclick=\"event.stopPropagation()\">AI Micro-Tools Guide</a></div>\n<div class=\"font-mono text-gray-500 mt-2 pt-2 border-t border-gray-200\">Rights:</div>\n<div class=\"col-span-2 text-gray-500 text-xs italic leading-tight mt-2 pt-2 border-t border-gray-200\">Belongs to original creator. Saved for inspiration.</div>\n</div>\n</div>"
