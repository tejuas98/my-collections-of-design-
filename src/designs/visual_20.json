    "visual_html": "<div class=\"border-2 border-black rounded-xl overflow-hidden bg-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] w-full max-w-full mx-auto\">\n<div class=\"bg-[#f0e050] border-b-2 border-black px-4 py-1.5 flex items-center space-x-2\">\n<svg class=\"w-5 h-5 text-black\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path></svg>\n<span class=\"font-bold text-xs tracking-wide\">PACKAGE.JSON DEPLOY SCRIPT</span>\n</div>\n<div class=\"p-4 bg-[#1e1e1e]\">\n<div class=\"font-mono text-xs leading-relaxed\">\n<div class=\"text-[#d4d4d4]\">{</div>\n<div class=\"text-[#d4d4d4] ml-4\">\"<span class=\"text-[#9cdcfe]\">scripts</span>\": {</div>\n<div class=\"text-[#d4d4d4] ml-8\">\"<span class=\"text-[#9cdcfe]\">dev</span>\": \"<span class=\"text-[#ce9178]\">astro dev</span>\",</div>\n<div class=\"text-[#d4d4d4] ml-8\">\"<span class=\"text-[#9cdcfe]\">build</span>\": \"<span class=\"text-[#ce9178]\">astro build</span>\",</div>\n<div class=\"text-[#d4d4d4] ml-8 bg-[#3c3c3c] border border-[#555] rounded px-1 relative group\">\n                \"<span class=\"text-[#9cdcfe]\">deploy</span>\": \"<span class=\"text-[#ce9178]\">astro build &amp;&amp; wrangler pages deploy</span>\"\n            </div>\n<div class=\"text-[#d4d4d4] ml-4\">}</div>\n<div class=\"text-[#d4d4d4]\">}</div>\n</div>\n<div class=\"mt-3 border-t border-gray-700 pt-4\">\n<div class=\"text-xs text-gray-400 mb-1 uppercase tracking-wider\">Future updates:</div>\n<div class=\"flex items-center space-x-2 bg-black rounded p-2 border border-gray-700 font-mono text-xs\">\n<span class=\"text-green-400\">$</span>\n<span class=\"text-white\">npm run deploy</span>\n</div>\n</div>\n</div>\n</div>",
    "metadata_html": "<div class=\"mb-4\">\n<h4 class=\"font-medium font-sans text-white text-sm mb-2\">Why I saved this:</h4>\n<ul class=\"list-disc pl-5 font-sans text-sm text-[var(--arsenal-text)] space-y-1\"><li>High contrast monospaced typography</li><li>Realistic macOS traffic lights</li><li>Clean shadow elevation</li></ul>\n</div>\n<div class=\"mb-6\">\n<h4 class=\"font-medium font-sans text-white text-sm mb-2\">What I can learn:</h4>\n<ul class=\"list-disc pl-5 font-sans text-sm text-[var(--arsenal-text)] space-y-1\"><li>How to build realistic code snippets</li><li>Simulating CLI outputs in HTML</li></ul>\n</div>\n<!-- RESTORED: SOURCE METADATA -->\n<div class=\"transparent p-4 rounded border border-white/20 text-sm mt-4 hidden\">\n<div class=\"grid grid-cols-3 gap-y-2 gap-x-4\">\n<div class=\"font-mono text-gray-500\">Creator:</div>\n<div class=\"col-span-2 font-medium text-[var(--text-primary)]\">Tejas Jaware</div>\n<div class=\"font-mono text-gray-500\">Source:</div>\n<div class=\"col-span-2 text-[var(--text-primary)]\"><a class=\"underline font-bold text-[var(--text-primary)] hover:text-indigo-500\" href=\"paper_micro_tool.html\" onclick=\"event.stopPropagation()\">AI Micro-Tools Guide</a></div>\n<div class=\"font-mono text-gray-500 mt-2 pt-2 border-t border-gray-200\">Rights:</div>\n<div class=\"col-span-2 text-gray-500 text-xs italic leading-tight mt-2 pt-2 border-t border-gray-200\">Belongs to original creator. Saved for inspiration.</div>\n</div>\n</div>"
